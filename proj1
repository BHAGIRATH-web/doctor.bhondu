<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pookie Story V5 😏</title>

<style>
body {
    text-align: center;
    font-family: 'Comic Sans MS', cursive;
    background: linear-gradient(135deg, #ff9a9e, #fad0c4);
    overflow: hidden;
}

h1 { margin-top: 60px; color: #ff2e88; }

button {
    padding: 12px 18px;
    border-radius: 20px;
    border: none;
    cursor: pointer;
    margin: 10px;
    background:#a0c4ff;
}

input {
    padding: 10px;
    border-radius: 10px;
    border: none;
    text-align: center;
}

.screen { display:none; }

#bar {
width:0%;
height:10px;
background:#ff2e88;
margin-top:20px;
}

.heart{
position:absolute;
animation:float 6s linear infinite;
}
@keyframes float{
from{transform:translateY(100vh);}
to{transform:translateY(-10vh);opacity:0;}
}

</style>
</head>

<body>

<!-- STEP 1 -->
<div id="s1" class="screen" style="display:block;">
<h1>Oye 😏 naam batao pehle</h1>
<input id="nameInput" placeholder="Your name...">
<br><br>
<button onclick="step1()">Continue 💖</button>
</div>

<!-- STEP 2 -->
<div id="s2" class="screen">
<h1 id="t2"></h1>
<button onclick="step2()">Haan 😏</button>
<button onclick="step2()">Nahi 😤</button>
</div>

<!-- STEP 3 -->
<div id="s3" class="screen">
<h1>Thoda drama karti ho kya? 🎭</h1>
<button onclick="step3()">Haan 😭</button>
<button onclick="step3()">Kabhi nahi 😈</button>
</div>

<!-- STEP 4 -->
<div id="s4" class="screen">
<h1 id="t4"></h1>
<button onclick="step4()">Sherni mode ON 😏</button>
<button onclick="step4()">Silent mode 😤</button>
</div>

<!-- STEP 5 -->
<div id="s5" class="screen">
<h1>Achha sach batao 😏</h1>
<button onclick="step5()">Mood swings kabhi kabhi 😭</button>
<button onclick="step5()">Full control 😤</button>
</div>

<!-- STEP 6 -->
<div id="s6" class="screen">
<h1>Analyzing personality 👀</h1>
<div id="bar"></div>
</div>

<!-- STEP 7 -->
<div id="s7" class="screen">
<h1>Lie detector ON 😈</h1>
</div>

<!-- STEP 8 -->
<div id="s8" class="screen">
<h1 id="t8"></h1>
</div>

<!-- STEP 9 -->
<div id="s9" class="screen">
<h1>Final stage 😏</h1>
<button onclick="step9()">Continue 💖</button>
</div>

<!-- STEP 10 -->
<div id="s10" class="screen">
<h1>Mysha ji 💖</h1>
<p id="finalText" style="max-width:500px;margin:auto;"></p>
</div>

<script>

let name="";

// helper
function show(id){
document.querySelectorAll('.screen').forEach(s=>s.style.display="none");
document.getElementById(id).style.display="block";
}

// STEP 1
function step1(){
name=document.getElementById("nameInput").value;
if(name===""){alert("Naam 😭");return;}

show("s2");
document.getElementById("t2").innerHTML =
"Hey " + name + " 😏… ready for a small test?";
}

// STEP 2
function step2(){
show("s3");
}

// STEP 3
function step3(){
show("s4");
document.getElementById("t4").innerHTML =
"Oho Sherni " + name + " 🐯💖… true?";
}

// STEP 4
function step4(){
show("s5");
}

// STEP 5
function step5(){
show("s6");
animateBar();
}

// STEP 6 loading
function animateBar(){
let w=0;
let bar=setInterval(()=>{
w+=5;
document.getElementById("bar").style.width=w+"%";
if(w>=100){
clearInterval(bar);
setTimeout(()=>{
show("s7");
setTimeout(step7,1500);
},500);
}
},100);
}

// STEP 7
function step7(){
show("s8");
document.getElementById("t8").innerHTML =
"Result: 💖 Drama level HIGH + Cute overload detected 😏";
setTimeout(step8,2000);
}

// STEP 8
function step8(){
show("s9");
}

// STEP 9
function step9(){
show("s10");

let msg =
"Dekha 😏 Sherni mode confirm ho gaya...\n\n" +

"par sun Mysha 💖\n\n" +

"chahe drama ho, silence ho, ya mood swings...\n" +
"sab ok hai 🙂\n\n" +

"bas ek baat yaad rakhna...\n\n" +

"yahan koi judge nahi karega 😤💖\n\n" +

"Yash hoon main...\n" +
"bas yahin rahunga 🐯";

let i=0;
function type(){
if(i<msg.length){
document.getElementById("finalText").innerHTML+=msg.charAt(i);
i++;
setTimeout(type,40);
}
}
type();
}

// hearts
setInterval(()=>{
let h=document.createElement("div");
h.className="heart";
h.innerHTML="💖";
h.style.left=Math.random()*100+"vw";
h.style.fontSize=(15+Math.random()*20)+"px";
document.body.appendChild(h);
setTimeout(()=>h.remove(),6000);
},300);

</script>

</body>
</html>
